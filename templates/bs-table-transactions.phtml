{if $unclearedAmount > 0}
<div class="text-end">
	<strong><em>{$unclearedAmount} uncleared</em></strong>
</div>
{/if}

<table class="table table-striped">
<thead>
<tr>
	<th colspan=3>
	&nbsp;
	</th>
	<th><i>amount</i></th>
	<th class="text-end"><i>balance</i></th>
</tr>
</thead>
<tbody>

{if $transactions}
{foreach $transactions as $index => $t}
	{if $t->balance <= 0}
		{$context = 'class="table-danger"'}
	{elseif !$t->cleared && !$t->credit}
		{$context = 'class="table-info"'}
	{elseif $t->credit}
		{$context = 'class="table-success"'}
	{else}
		{$context = ''}
	{/if}
<tr {$context}>
	<td>
		<a href="{$thisScript}?verb=deleteModal&id={$t->id}" data-ajax-target="#deleteModal"><span class='bi bi-trash'></span></a>
	</td>

	<td>
		{$t->tshort}
	</td>

	<td>
		{$t->description}
	</td>

	<td>
	{if !$t->credit && !$t->cleared}
		<a href="{$thisScript}?verb=updateModal&id={$t->id}" data-ajax-target="#updateModal">{$t->formattedAmount}</a>
	{else}
		{$t->formattedAmount}
	{/if}
	</td>

	<td class="text-end">
	{if !$index}
		<b>{$t->formattedBalance}</b>
	{else}
		{$t->formattedBalance}
	{/if}
	</td>
</tr>
{/foreach}
{/if}

{if $unclearedTransactions}
{foreach $unclearedTransactions as $t}
<tr class="table-warning uncleared">
	<td>
		<a href="{$thisScript}?verb=deleteModal&id={$t->id}" data-ajax-target="#deleteModal"><span class='bi bi-trash'></span></a>
	</td>

	<td>
		{$t->tshort}
	</td>

	<td>
		{$t->description}
	</td>

	<td>
		<a href="{$thisScript}?verb=updateModal&id={$t->id}" data-ajax-target="#updateModal">{$t->formattedAmount}</a>
	</td>

	<td class="text-end">OLD</td>
</tr>
{/foreach}
{/if}
<tr class='mutable'>
	<td colspan=5>
		<button id="moreTransactions" nextwindowend="{$nextWindowEnd}" type="button" class="btn btn-secondary btn-lg w-100">Load more</button>
	</td>
</tr>
</tbody>
</table>

<div id="updateModal" class="modal" role="dialog" tabindex="-1">
  <div class="modal-dialog modal-sm">
	<div class="modal-content">
		<!-- this will be replaced -->
	</div>
  </div>
</div>

<div id="deleteModal" class="modal" role="dialog" tabindex="-1">
  <div class="modal-dialog modal-sm">
	<div class="modal-content">
		<!-- this will be replaced -->
	</div>
  </div>
</div>

<script type='text/javascript'>
function bindMoreTransactionsClick() {
	$('#moreTransactions').click(function() {
		var nextWindowEnd = $("#moreTransactions").attr("nextwindowend");
		$('tr.uncleared').remove();
		$('tr.mutable').remove();
		$.ajax({
			type: "POST",
			url: "{$thisScript}",
			data: {
				verb: "moreTransactions",
				windowEndDate: nextWindowEnd
			},
			success: function(data) {
				$('tr:last').after(data);
			}
		});
		return false;
	});
}
bindMoreTransactionsClick();
</script>
